{
	"name": "my-mcp-app",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"deploy": "bunx wrangler deploy --minify",
		"deploy:preview": "bunx wrangler deploy --preview",
		"cf-typegen": "wrangler types",
		"deploy:tail": "bunx wrangler tail",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@phake/mcp": "^0.3.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"wrangler": "^4.80.0"
	}
}
