# Cloudflare Workers MCP Server with Google OAuth

# KV Namespace - create via: wrangler kv namespace create TOKENS
RS_TOKENS_ENC_KEY=

# Required: OAuth client (your MCP app)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Required: OAuth redirect URI (update "your-worker" to your actual worker)
OAUTH_REDIRECT_URI=https://your-worker.workers.dev/oauth/provider-callback

# Optional: OAuth scopes (default: "openid email profile")
# OAUTH_SCOPES=openid email profile